<?xml version="1.0" encoding="utf-8"?>
<!--
  XrmToolBox Tool Store package manifest.

  Store requirements (xrmtoolbox.com → for-developers → deploy-your-plugin):
    • tags must contain "XrmToolBox"
    • an iconUrl (external logo) is mandatory, or the tool is refused
    • a <dependency id="XrmToolBox"> marks the minimum host version (this is a
      metadata marker; there is no restorable "XrmToolBox" package)
    • plugin assemblies go under lib\net48\Plugins

  $version$ is replaced at pack time from Directory.Build.props (see the .csproj
  NuspecProperties). The DLLs come from deploy\Plugins (build\package.ps1).
-->
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>LookupImportPlus</id>
    <version>$version$</version>
    <title>LookupImportPlus</title>
    <authors>brunsforge</authors>
    <owners>brunsforge</owners>
    <projectUrl>https://github.com/brunsforge/XMRToolbox_LookupImportPlus</projectUrl>
    <!-- iconUrl only (no embedded <icon>) — matches the canonical MscrmTools /
         Cinteros plugins. An embedded icon makes nuget rewrite/override the icon
         handling, which the Tool Library rejected ("Logo Url is not valid"). -->
    <iconUrl>https://raw.githubusercontent.com/brunsforge/XMRToolbox_LookupImportPlus/master/build/pack/icon.png</iconUrl>
    <readme>README.md</readme>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <summary>Deterministic, auditable Excel import for Dataverse — lookups are never guessed.</summary>
    <description>Auditierbarer Excel-Import in Dataverse, bei dem Lookups deterministisch aufgeloest oder an einen Menschen eskaliert werden — nie geraten. Feste Reihenfolge GUID -&gt; Business Key -&gt; Suchfeld, versionierte Konfigurationen, Round-Trip (Export/Dry Run/Konflikte/Commit) und Audit-Log. Bulk-Writes ueber ExecuteMultipleRequest.</description>
    <releaseNotes>
0.1.1: MIT-Lizenz, Paket-Readme und XrmToolBox-Tool-Library-Metadaten (Icon + Host-Dependency).
0.1.0: Erste Version — deterministischer, auditierbarer Excel-Import mit sicherer Lookup-Aufloesung.
    </releaseNotes>
    <copyright>Copyright (c) 2026 brunsforge</copyright>
    <tags>XrmToolBox Plugins Dataverse Excel Import Lookup</tags>
    <dependencies>
      <!-- Marker for the XrmToolBox Tool Library (no such nuget package exists).
           Uses the exact host version we build against (= XrmToolBoxPackage), the
           same value the canonical MscrmTools plugins declare. -->
      <dependency id="XrmToolBox" version="1.2025.10.74" />
    </dependencies>
  </metadata>
  <files>
    <file src="..\..\deploy\Plugins\*.dll" target="lib\net48\Plugins" />
    <file src="PACKAGE.md" target="README.md" />
  </files>
</package>
