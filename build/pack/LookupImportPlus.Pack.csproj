<!--
  Produces the XrmToolBox Tool Store package (.nupkg) from the hand-written
  LookupImportPlus.nuspec (full control over iconUrl, the XrmToolBox dependency
  marker, releaseNotes and the lib\net48\Plugins layout the store expects).

  Usage:
    build\package.ps1                                   # populate deploy\Plugins
    dotnet pack build\pack\LookupImportPlus.Pack.csproj -c Release -o deploy
    # → deploy\LookupImportPlus.<version>.nupkg   (version from Directory.Build.props)
-->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IsPackable>true</IsPackable>
    <EnableDefaultItems>false</EnableDefaultItems>

    <!-- Pack the hand-written nuspec; inject the single-source version. -->
    <NuspecFile>LookupImportPlus.nuspec</NuspecFile>
    <NuspecBasePath>$(MSBuildProjectDirectory)</NuspecBasePath>
    <NuspecProperties>version=$(Version)</NuspecProperties>

    <!-- NU5048: iconUrl is deprecated on nuget.org, but XrmToolBox REQUIRES it;
         we also ship an embedded <icon> for nuget.org's own display. -->
    <NoWarn>NU5048</NoWarn>
  </PropertyGroup>

</Project>
